{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/cron/sync-fixtures",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/sync-squads",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/sync-lineups",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/live-score",
      "schedule": "* * * * *"
    }
  ]
}
